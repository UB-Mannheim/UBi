OPENAI_API_KEY=dummy_for_vLLM
OPENAI_BASE_URL=http://localhost:8001/v1
# Enable (True) or disable (False) OpenAI vectorstore usage
USE_OPENAI_VECTORSTORE=False
ROUTER_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8
# CHAT_MODEL=Qwen/Qwen3.5-27B
CHAT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507-FP8

# The Ollama settings are used when OPENAI_API_KEY is not set.
# Base URL for Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Ollama models for router, chat and embedding
OLLAMA_ROUTER_MODEL=gemma4:e2b
OLLAMA_CHAT_MODEL=gemma4
# 8192, 1024, 200
#OLLAMA_EMBEDDING_MODEL=bge-m3
#OLLAMA_EMBEDDING_MODEL=hellord/e5-mistral-7b-instruct:Q8_0
# 512, 512, 40
#OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
# 8192, 1024, 200
#OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
# 8192, 800, 100
CHUNK_SIZE=800
CHUNK_OVERLAP=100
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:8b

# Common settings which are always used.
# in days; Delete backups of /data/markdown and /data/markdown_processed after 7 days
DELETE_BACKUPS_AFTER=7
# Enable to suppress all non-error messages and progress bars in CLI
QUIET_MODE=False

# Additional settings
# Remove select library areas from occupancy plot
DISABLED_AREAS=a3,a5

# Enable incremental vector store updates (default: true)
VECTORSTORE_INCREMENTAL=true

# Audio Settings (optional – both default to False / disabled)
# Enable speech-to-text input via Faster-Whisper
ENABLE_AUDIO_INPUT=False
# Enable text-to-speech output via Silero TTS
ENABLE_AUDIO_OUTPUT=False
# Whisper model size: tiny, base, small, medium, large (default: base)
WHISPER_MODEL=base
# Whisper inference device: cpu or cuda (default: cpu)
WHISPER_DEVICE=cpu
# Silero TTS language code (default: de)
TTS_LANGUAGE=de
# Silero TTS speaker name (default: thorsten)
# German speakers: thorsten (male), eva_k (female), karlsson (male)
# English speakers: en_0, en_1, ...
TTS_SPEAKER=eva_k
# Silero TTS sample rate in Hz (default: 48000)
TTS_SAMPLE_RATE=48000
