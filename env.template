OPENAI_API_KEY=sk-
# Enable (True) or disable (False) OpenAI vectorstore usage
USE_OPENAI_VECTORSTORE=False
ROUTER_MODEL=gpt-4.1-nano-2025-04-14
CHAT_MODEL=gpt-4.1-mini-2025-04-14

# The Ollama settings are used when OPENAI_API_KEY is not set.
# Base URL for Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ROUTER_MODEL=llama3.2
# Ollama chat model
OLLAMA_CHAT_MODEL=llama3.2
# Ollama embedding model
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Common settings which are always used.
# in days; Delete backups of /data/markdown and /data/markdown_processed after 7 days
DELETE_BACKUPS_AFTER=7
# enable to suppress all non-error messages and progress bars in CLI
QUIET_MODE=False
